  "panels": [
    {
      "datasource": {
        "type": "postgres",
        "uid": "alert-db"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "showPercentChange": false,
        "textMode": "value",
        "wideLayout": true
      },
      "targets": [
        {
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT COUNT(*) AS value FROM alerts WHERE $__timeFilter(created_at);",
          "refId": "A"
        }
      ],
      "title": "Alerts (Selected Range)",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "postgres",
        "uid": "alert-db"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 0
      },
      "id": 2,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "showPercentChange": false,
        "textMode": "value",
        "wideLayout": true
      },
      "targets": [
        {
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT COALESCE(ROUND(AVG(risk_score)::numeric, 2), 0) AS value FROM alerts WHERE $__timeFilter(created_at);",
          "refId": "A"
        }
      ],
      "title": "Average Risk Score",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "postgres",
        "uid": "alert-db"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.2
              },
              {
                "color": "red",
                "value": 0.5
              }
            ]
          },
          "unit": "percentunit"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 0
      },
      "id": 3,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "showPercentChange": false,
        "textMode": "value_and_name",
        "wideLayout": true
      },
      "targets": [
        {
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT COALESCE(SUM(CASE WHEN risk_score >= 85 THEN 1 ELSE 0 END)::numeric / NULLIF(COUNT(*), 0), 0) AS value FROM alerts WHERE $__timeFilter(created_at);",
          "refId": "A"
        }
      ],
      "title": "Critical Risk Ratio (>=85)",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "postgres",
        "uid": "alert-db"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 16,
            "showPoints": "never"
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 10,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "id": 4,
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      },
      "targets": [
        {
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT $__timeGroupAlias(created_at, '1m'), COUNT(*)::double precision AS \"alerts\" FROM alerts WHERE $__timeFilter(created_at) GROUP BY 1 ORDER BY 1;",
          "refId": "A"
        }
      ],
      "title": "Alerts Timeline",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "postgres",
        "uid": "alert-db"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "align": "auto"
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 10,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "id": 5,
      "options": {
        "orientation": "auto",
        "xTickLabelRotation": 0,
        "xTickLabelSpacing": 100
      },
      "targets": [
        {
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT reason AS metric, COUNT(*)::double precision AS value FROM alerts, LATERAL regexp_split_to_table(reasons, ',') AS reason WHERE $__timeFilter(created_at) GROUP BY reason ORDER BY value DESC LIMIT 8;",
          "refId": "A"
        }
      ],
      "title": "Top Triggered Reasons",
      "type": "barchart"
    },
    {
      "datasource": {
        "type": "postgres",
        "uid": "alert-db"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "trace_id"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "Trace ID"
              },
              {
                "id": "links",
                "value": [
                  {
                    "targetBlank": true,
                    "title": "Open in Tempo",
                    "url": "/explore?orgId=1&left=%7B%22datasource%22:%22tempo%22,%22queries%22:%5B%7B%22query%22:%22${__value.raw}%22%7D%5D%7D"
                  }
                ]
              }
            ]
          }
        ]
      },
      "gridPos": {
        "h": 12,
        "w": 24,
        "x": 0,
        "y": 18
      },
      "id": 6,
      "options": {
        "cellHeight": "sm",
        "showHeader": true,
        "footer": {
          "show": false,
          "reducer": [
            "sum"
          ],
          "fields": ""
        }
      },
      "targets": [
        {
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT created_at, id AS alert_id, transaction_id, user_id, risk_score, reasons, COALESCE(trace_id, '') AS trace_id FROM alerts ORDER BY created_at DESC LIMIT 200;",
          "refId": "A"
        }
      ],
      "title": "Latest Alerts (DB)",
      "type": "table"
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
